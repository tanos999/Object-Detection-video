# Dependencies
node_modules/
client/node_modules/
server/node_modules/

# Python virtual environment
ml-server/venv/
ml-server/__pycache__/
ml-server/*.pyc
ml-server/*.pyo

# Uploaded videos (user data, not source code)
server/uploads/*.mp4
server/uploads/*.mov
server/uploads/frames_*/

# YOLO model weights (large binary, downloaded automatically)
ml-server/*.pt

# Environment variable files
.env
server/.env
client/.env
ml-server/.env

# Build output
client/dist/

# OS files
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
